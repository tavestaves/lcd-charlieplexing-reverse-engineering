/* finder #include <Arduino.h>

const int pins[] = {2, 3, 4, 5, 6, 7};   // your 6 test pins
const int numPins = sizeof(pins) / sizeof(pins[0]);

int i = 0;  // HIGH pin index
int j = 1;  // LOW pin index

// Function declarations (needed for PlatformIO)
void showPair(int highIndex, int lowIndex);
void nextPair();

void setup() {
  Serial.begin(9600);
  Serial.println("=== Charlieplex Tester ===");
  Serial.println("Press ENTER in Serial Monitor to step to the next pair.");
  Serial.println("Observing pin pairs...");

  for (int k = 0; k < numPins; k++) {
    pinMode(pins[k], INPUT); // high-Z
  }

  showPair(i, j);  // show first pair
}

void loop() {
  static bool waitingForRelease = false;

  if (Serial.available()) {
    char c = Serial.read();

    // Only react to first Enter press (ignore repeats)
    if (!waitingForRelease && (c == '\n' || c == '\r')) {
      waitingForRelease = true;  // ignore extra chars for now
      nextPair();
      delay(200); // debounce delay
    }

    // Clear input buffer if user spammed Enter
    while (Serial.available()) Serial.read();
  }

  // After delay, allow next press
  if (waitingForRelease && millis() % 300 == 0) {
    waitingForRelease = false;
  }
}

void nextPair() {
  j++;
  if (j >= numPins) {
    j = 0;
    i++;
    if (i >= numPins) {
      Serial.println("✅ Done — All combinations tested!");
      i = 0;
      j = 1;
    }
  }
  if (i == j) nextPair(); // skip same pin
  else showPair(i, j);
}

void showPair(int highIndex, int lowIndex) {
  // Set all pins high-Z
  for (int k = 0; k < numPins; k++) {
    pinMode(pins[k], INPUT);
  }

  // Drive one HIGH and one LOW
  pinMode(pins[highIndex], OUTPUT);
  digitalWrite(pins[highIndex], HIGH);

  pinMode(pins[lowIndex], OUTPUT);
  digitalWrite(pins[lowIndex], LOW);

  Serial.print("Now driving: ");
  Serial.print(pins[highIndex]);
  Serial.print(" HIGH → ");
  Serial.print(pins[lowIndex]);
  Serial.print(" LOW");
  Serial.print("  (Pair ");
  Serial.print((i * (numPins - 1)) + j);
  Serial.println(")");
}
